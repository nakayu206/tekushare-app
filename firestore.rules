rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 自分と otherUid が連携済みかどうかを確認する
    // linkId は2つのUIDをソートして _ でつないだもの（AccountLinkRepositoryImpl._linkIdOf と同一）
    function isLinkedWith(otherUid) {
      let linkId = request.auth.uid < otherUid
        ? request.auth.uid + '_' + otherUid
        : otherUid + '_' + request.auth.uid;
      return exists(/databases/$(database)/documents/accountLinks/$(linkId));
    }

    // users/{uid}: 連携相手の表示名・共有設定を引けるよう読み取りはログイン済み全員に許可
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // users/{uid}/contacts, spots, photos などサブコレクションはオーナーのみ
    match /users/{uid}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // 連携済みユーザーは相手の共有設定に応じてスポットを読み取り可
    match /users/{uid}/spots/{spotId} {
      // 単一取得: ステータスに対応する共有設定を確認（フィールド未設定はデフォルトON）
      allow get: if isSignedIn()
        && isLinkedWith(uid)
        && (
          (resource.data.status == 'wantToGo'
            && get(/databases/$(database)/documents/users/$(uid)).data.shareWantToGo != false)
          || (resource.data.status == 'visited'
            && get(/databases/$(database)/documents/users/$(uid)).data.shareVisited != false)
        );
      // コレクションクエリ: LIST では resource.data が使えないため連携確認のみ
      // クライアント側が shareSettings を確認した上で対象ステータスのみ whereIn で絞る
      allow list: if isSignedIn() && isLinkedWith(uid);
    }

    match /linkInvites/{token} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.used == false;

      allow update: if isSignedIn()
        && resource.data.fromUid != request.auth.uid
        && resource.data.used == false
        && request.resource.data.used == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used']);

      allow delete: if false;
    }

    match /accountLinks/{linkId} {
      // resource == null は未作成ドキュメントの存在確認（連携済みチェック）を許可する
      allow read: if isSignedIn() && (resource == null || request.auth.uid in resource.data.uids);

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.uids
        && request.resource.data.uids.size() == 2
        && exists(/databases/$(database)/documents/linkInvites/$(request.resource.data.inviteToken))
        && get(/databases/$(database)/documents/linkInvites/$(request.resource.data.inviteToken)).data.fromUid != request.auth.uid
        && get(/databases/$(database)/documents/linkInvites/$(request.resource.data.inviteToken)).data.fromUid in request.resource.data.uids
        && get(/databases/$(database)/documents/linkInvites/$(request.resource.data.inviteToken)).data.used == false;

      allow update: if false;

      allow delete: if isSignedIn() && request.auth.uid in resource.data.uids;
    }
  }
}
